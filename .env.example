# Copy to `.env` and fill in values. Never commit `.env`.
# `NEXT_PUBLIC_*` is exposed to the browser; other variables are server-only.

# Sanity — https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Resend — contact form (https://resend.com/api-keys)
RESEND_API_KEY=

# --- Optional: local runs of scripts/scholar-stats/sync.py (Google Scholar → Sanity) ---
# Not required for `npm run dev` / Vercel. GitHub Actions uses repository secrets instead.
# SERPAPI_API_KEY=
# GOOGLE_SCHOLAR_AUTHOR_ID=   # user id from scholar URL, or use SCHOLAR_PROFILE_URL below
# SCHOLAR_PROFILE_URL=       # full profile URL containing user=...
# SANITY_PROFILE_DOCUMENT_ID=  # optional; omit to auto-detect *[_type == "profile"][0]
